DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Google AI Studio で作成した Gemini API キー
GEMINI_API_KEY=""
# Optional: defaults to gemini-3.5-flash
GEMINI_MODEL="gemini-3.5-flash"

# サーバー側でカレンダーの更新トークンを保持する場合に必要です。
# Google Cloud Console の OAuth 2.0 クライアントで、下記のリダイレクト URI を登録してください。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8888/api/calendar/callback"

# OAuth完了後に戻すフロントエンドのURL
APP_URL="http://localhost:5173"
